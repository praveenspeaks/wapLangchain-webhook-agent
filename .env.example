# =============================================================================
# WhatsApp AI Agent — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- LLM -------------------------------------------------------------------
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Shivay API ----------------------------------------------------------
SHIVAY_API_URL=https://your-shivay-api.example.com
SHIVAY_API_KEY=your-api-key
SHIVAY_INSTANCE_NAME=your_instance_name
SHIVAY_INSTANCE_TOKEN=your-instance-token

# --- Database (PostgreSQL) --------------------------------------------------
# LangGraph checkpointer + business data
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
POSTGRES_URL=postgres://user:pass@host:5432/dbname
TESTING_DB_URL=postgres://user:pass@host:5432/dbname

# --- Webhook ----------------------------------------------------------------
WEBHOOK_SECRET=change-me-to-a-long-random-string
WEBHOOK_URL=https://your-ngrok-url.ngrok-free.dev/webhook/shivay

# --- Rate Limiting ----------------------------------------------------------
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60

# --- Application ------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- ngrok (local dev only) -------------------------------------------------
NGROK_AUTHTOKEN=your-ngrok-authtoken
