{
  "name": "AI Agent Webhook",
  "description": "LangGraph agent with Groq LLM, invoked via webhook, replies in HTTP response.",
  "version": "1.0.0",
  "entryPoint": "main.py",
  "port": 8000,
  "healthCheck": {
    "path": "/health",
    "port": 8000
  },
  "language": "python",
  "framework": "langgraph",
  "llm": "groq/llama-3.1-8b-instant",
  "tools": [
    "get_order_status",
    "get_orders_by_status",
    "search_product",
    "get_product_info",
    "get_event_tickets",
    "create_support_ticket",
    "get_business_hours"
  ],
  "endpoints": {
    "agent": {
      "path": "/invoke",
      "method": "POST"
    },
    "health": "/health",
    "metrics": "/metrics"
  },
  "dependencies": [
    "langgraph",
    "langchain",
    "langchain-groq",
    "fastapi",
    "uvicorn",
    "psycopg",
    "psycopg-pool",
    "pydantic",
    "python-json-logger",
    "python-dotenv"
  ],
  "docker": {
    "compose": "docker-compose.yml",
    "dockerfile": "Dockerfile"
  },
  "env": [
    "GROQ_API_KEY",
    "POSTGRES_URL",
    "LOG_LEVEL",
    "ENVIRONMENT"
  ]
}
